{
  "dataRoles": [
    {
      "displayName": "Value",
      "displayNameKey": "Role_Value",
      "name": "measure",
      "kind": "Measure",
      "description": "Current period value (required).",
      "descriptionKey": "Role_Value_Description"
    },
    {
      "displayName": "Prior Period",
      "displayNameKey": "Role_PriorPeriod",
      "name": "priorPeriod",
      "kind": "Measure",
      "description": "Prior period value for variance calculation (optional).",
      "descriptionKey": "Role_PriorPeriod_Description"
    },
    {
      "displayName": "Target",
      "displayNameKey": "Role_Target",
      "name": "target",
      "kind": "Measure",
      "description": "Target or budget value (optional).",
      "descriptionKey": "Role_Target_Description"
    },
    {
      "displayName": "Small Multiples",
      "displayNameKey": "Role_SmallMultiples",
      "name": "smallMultiples",
      "kind": "Grouping",
      "description": "Dimension to split into multiple KPI cards (optional, Pro).",
      "descriptionKey": "Role_SmallMultiples_Description"
    },
    {
      "displayName": "Tooltips",
      "displayNameKey": "Role_Tooltips",
      "name": "tooltips",
      "kind": "Measure",
      "description": "Additional measures for tooltip (optional, Pro).",
      "descriptionKey": "Role_Tooltips_Description"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "measure": {
            "max": 1
          },
          "priorPeriod": {
            "max": 1
          },
          "smallMultiples": {
            "max": 1
          },
          "tooltips": {
            "max": 10
          },
          "target": {
            "max": 1
          }
        }
      ],
      "matrix": {
        "rows": {
          "select": [
            {
              "for": {
                "in": "smallMultiples"
              }
            }
          ],
          "dataReductionAlgorithm": {
            "top": {
              "count": 50
            }
          }
        },
        "values": {
          "select": [
            {
              "bind": {
                "to": "measure"
              }
            },
            {
              "bind": {
                "to": "target"
              }
            },
            {
              "bind": {
                "to": "priorPeriod"
              }
            },
            {
              "bind": {
                "to": "tooltips"
              }
            }
          ]
        }
      }
    }
  ],
