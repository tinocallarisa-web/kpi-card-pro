{
  "dataRoles": [
    {
      "displayName": "Value",
      "displayNameKey": "Role_Value",
      "name": "measure",
      "kind": "Measure",
      "description": "Current period value (required). One measure only.",
      "descriptionKey": "Role_Value_Description"
    },
    {
      "displayName": "Prior Period",
      "displayNameKey": "Role_PriorPeriod",
      "name": "priorPeriod",
      "kind": "Measure",
      "description": "Prior period value for variance calculation (optional).",
      "descriptionKey": "Role_PriorPeriod_Description"
    },
    {
      "displayName": "Target",
      "displayNameKey": "Role_Target",
      "name": "target",
      "kind": "Measure",
      "description": "Target or budget value for goal tracking (optional).",
      "descriptionKey": "Role_Target_Description"
    },
    {
      "displayName": "Category",
      "displayNameKey": "Role_Category",
      "name": "category",
      "kind": "Grouping",
      "description": "Dimension for sparkline trend chart (optional).",
      "descriptionKey": "Role_Category_Description"
    },
    {
      "displayName": "Tooltips",
      "displayNameKey": "Role_Tooltips",
      "name": "tooltips",
      "kind": "Measure",
      "description": "Additional measures for report page tooltip or custom tooltip payload (optional).",
      "descriptionKey": "Role_Tooltips_Description"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "measure": {
            "max": 1
          },
          "priorPeriod": {
            "max": 1
          },
          "target": {
            "max": 1
          },
          "category": {
            "max": 1
          },
          "tooltips": {
            "max": 10
          }
        }
      ],
      "categorical": {
        "categories": {
          "select": [
            {
              "for": {
                "in": "category"
              }
            }
          ],
          "dataReductionAlgorithm": {
            "top": {
              "count": 100
            }
          }
        },
        "values": {
          "select": [
            {
              "bind": {
                "to": "measure"
              }
            },
            {
              "bind": {
                "to": "priorPeriod"
              }
            },
            {
              "bind": {
                "to": "target"
              }
            },
            {
              "bind": {
                "to": "tooltips"
              }
            }
          ]
        }
      }
    }
  ],
